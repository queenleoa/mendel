# Neon (or any) Postgres connection string
DATABASE_URL=postgresql://user:pw@host/dbname?sslmode=require

# Hot wallet for autonomous agent operations on Galileo + Base Sepolia.
# Demo only — never reuse for anything real.
AGENT_PRIVATE_KEY=0x...

# 0G Galileo testnet RPC
ZERO_G_RPC=https://evmrpc-testnet.0g.ai

# Base Sepolia RPC for Uniswap V3 swaps (Phase 2)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# MendelAgent contract address on Galileo
MENDEL_AGENT_ADDRESS=0x...

# Vercel cron secret (sent in Authorization: Bearer <secret>)
CRON_SECRET=change-me

# Frontend origin allowed to hit /api/* (set to your Vercel URL in prod)
ALLOWED_ORIGIN=*
